  "source_code": "module debounce \n#(\n\tparameter  N         =  2,\n\tparameter  CNT_20MS  =  19'h75601//?\u03bc\u00ed3\u00ea\u00b1?\u00f324MHz\uffe1?\u00f2a?\u00f3\u00ea\u00b120ms\u00d7\u00f3\u00f3\u00f2\u00ea\u00b1??\n)\n(\n\tinput\twire         clk,\n\tinput\twire         rst_n,\n\t// key\n\tinput   wire [N-1:0] key,\n\toutput\twire [N-1:0] key_pulse\n); \n  \nreg [18:0]\tcnt; //2\u00fa\u00e9\u00fa?\u00f3\u00ea\u00b1?\u00f9\u00f3?\u03bc???\u00eay?\u00f7\uffe1??\u03bc\u00ed3\u00ea\u00b1?\u00f324MHz\uffe1?\u00f2a?\u00f3\u00ea\u00b120ms\u00d7\u00f3\u00f3\u00f2\u00ea\u00b1??   \n\nalways@(posedge clk or negedge rst_n)\nbegin\n     if(!rst_n)\n          cnt <= 0;\n     else if(cnt == CNT_20MS)\n          cnt <= 0;\n     else\n          cnt <= cnt + 1'h1;\nend  \n\nreg [N-1:0] key_sec_pre;                \nreg [N-1:0] key_sec;                      \n\nalways@(posedge clk  or  negedge rst_n)\nbegin\n     if(!rst_n) \n         key_sec <= {N{1'b1}};                \n     else if(cnt == CNT_20MS)\n         key_sec <= key;  \nend\n\nalways@(posedge clk  or  negedge rst_n)\nbegin\n     if(!rst_n)\n         key_sec_pre <= {N{1'b1}};\n     else                   \n         key_sec_pre <= key_sec;             \nend  \n    \nassign  key_pulse = ~key_sec & key_sec_pre ;     \n \nendmodule",
  "source_file": "debounce.v",
  "source_path": "debounce.v"
}